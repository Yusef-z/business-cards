---
interface Assoc {
  slug: string; name: string; logo: string;
  phone?: string; email?: string; website?: string; linkedin?: string; x?: string;
}
const { assoc } = Astro.props as { assoc: Assoc };

// Present the raw data in a human-friendly form (values stay LTR in the RTL card).
function formatPhone(p: string): string {
  const m = p.match(/^\+966(\d{2})(\d{3})(\d{4})$/);
  return m ? `+966 ${m[1]} ${m[2]} ${m[3]}` : p;
}
function displayHost(url: string): string {
  return url.replace(/^https?:\/\//, "").replace(/^www\./, "").replace(/\/+$/, "");
}

const icons = {
  save: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>',
  phone: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  email: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
  website: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
  linkedin: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>',
  x: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 1.15h3.68l-8.05 9.2L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.42l8.6-9.83L0 1.15h7.6l5.24 6.93 6.06-6.93zm-1.29 19.5h2.04L6.49 3.24H4.3l13.31 17.41z"/></svg>',
  go: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>',
};
---
<article class="card">
  <div class="card__hero">
    <img
      class="card__logo-img"
      src={assoc.logo}
      alt={assoc.name}
      onerror="this.style.display='none'"
    />
    <h1 class="card__name sr-only">{assoc.name}</h1>
  </div>
  <div class="card__seam"></div>
  <div class="card__body">
    <a class="btn--primary" href={`/vcards/${assoc.slug}.vcf`}>
      <span class="btn__icon" set:html={icons.save} />
      <span>حفظ جهة الاتصال</span>
    </a>

    {(assoc.phone || assoc.email || assoc.website) && (
      <div class="contacts">
        {assoc.phone && (
          <a class="row" href={`tel:${assoc.phone}`}>
            <span class="row__chip" set:html={icons.phone} />
            <span class="row__value" dir="ltr">{formatPhone(assoc.phone)}</span>
            <span class="row__go" set:html={icons.go} />
          </a>
        )}
        {assoc.email && (
          <a class="row" href={`mailto:${assoc.email}`}>
            <span class="row__chip" set:html={icons.email} />
            <span class="row__value" dir="ltr">{assoc.email}</span>
            <span class="row__go" set:html={icons.go} />
          </a>
        )}
        {assoc.website && (
          <a class="row" href={assoc.website} target="_blank" rel="noopener">
            <span class="row__chip" set:html={icons.website} />
            <span class="row__value" dir="ltr">{displayHost(assoc.website)}</span>
            <span class="row__go" set:html={icons.go} />
          </a>
        )}
      </div>
    )}

    {(assoc.linkedin || assoc.x) && (
      <div class="socials">
        {assoc.linkedin && (
          <a class="icon-btn icon-btn--linkedin" href={assoc.linkedin} target="_blank" rel="noopener" aria-label="لينكدإن" set:html={icons.linkedin} />
        )}
        {assoc.x && (
          <a class="icon-btn icon-btn--x" href={assoc.x} target="_blank" rel="noopener" aria-label="إكس" set:html={icons.x} />
        )}
      </div>
    )}
  </div>
</article>
