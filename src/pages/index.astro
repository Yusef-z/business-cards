      onerror="this.replaceWith(Object.assign(document.createElement('div'),{className:'card__logo-fallback',textContent:'نتاج'}))" />
    <h1 class="card__name" style="margin-bottom:0">الدليل التعريفي للجمعيات</h1>
  </div>
</Base>
